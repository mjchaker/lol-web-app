# Riot developer API key — get one at https://developer.riotgames.com
# Leave unset to run the app in demo mode with sample data.
RIOT_API_KEY=

# Your Riot ID (game name + tag line)
RIOT_ID=YourName#EUW

# Platform routing value: euw1, eun1, na1, kr, br1, jp1, oc1, tr1, ru, ...
RIOT_PLATFORM=euw1

# How many recent matches to display (max 20)
MATCH_COUNT=10

# Optional: background music track — a direct audio URL (mp3/ogg/wav) or a
# YouTube link (e.g. https://www.youtube.com/watch?v=IUZEtVbJT5c), which is
# played through a hidden YouTube embed.
# If unset, the app plays static/audio/summoners-rift.mp3 when present,
# otherwise the bundled ambient loop.
MUSIC_URL=
